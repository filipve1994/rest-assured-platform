# Copy to .env (gitignored) or export these directly in your shell / CI secrets.
# Never commit real values.

# --- Your own API under test (prod environment only - dev/qa/acc use plain yml values) ---
API_AUTH_CLIENTID=
API_AUTH_CLIENTSECRET=

# --- Public API examples (test-execution/src/test/java/com/framework/examples) ---
# Free key from https://reqres.in/signup - required for every ReqresApiTest to run;
# the whole class is skipped automatically if this isn't set.
REQRES_API_KEY=

# restful-api.dev and jsonplaceholder.typicode.com need no credentials at all.
